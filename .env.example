# Supabase pooled Postgres connection (same vars as lib/server/db.ts getSql())
PG_DATABASE=postgres
PG_PASSWORD=<PASSWORD>
PG_SSL_MODE=require

# Transaction pooler — port 6543. `psql` / scratch/foundation_all_food_april2026.py use this by default
# (session port 5432 often rejects the same DB password on Supavisor).
PG_POOL_USER=postgres.<organization-ref>
PG_POOL_HOST=aws-1-us-east-1.pooler.supabase.com
PG_POOL_TRANSACTION_PORT=6543
PG_POOL_SESSION_PORT=5432

# Optional: session pooler port (usually 5432). Only set PG_PSQL_USE_SESSION_POOLER_PORT=1 if 5432 auth works.


# Force pooler in URL builder even when direct resolves (rare):
# PG_PSQL_SESSION_POOLER=1

# Direct db.<project-ref>.supabase.co (Dashboard → Connect). Without IPv4 add-on this is often IPv6-only.
# After enabling IPv4 add-on, DNS may take a few minutes; if diagnose still shows direct BAD, flush macOS
# DNS (dscacheutil + mDNSResponder) and confirm `dig +short A db.<ref>.supabase.co @8.8.8.8` shows an A record.
PG_DIR_USER=postgres
PG_DIR_DATABASE=postgres
PG_DIR_HOST=db.<organization-ref>.supabase.co
PG_DIR_PORT=5432